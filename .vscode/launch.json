{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Test",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/supercrawler/main.py",
            "args": ["https://crawlme.monzo.com/"],
            "cwd": "${workspaceFolder}/supercrawler",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Pytest integration tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/integration/sub_domain_explorer_test.py"],
            "cwd": "${workspaceFolder}/supercrawler",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/supercrawler/src"
            }
        }
    ]
}
